+  setAllDaySelection = (enabled: boolean, onDone?: () => void) => {
+    if (enabled === this.state.selectionAllDay) {
+      onDone?.();
+      return;
+    }
+
+    if (enabled) {
+      this.resetEnterTime = new Date(this.state.enter);
+      this.resetLeaveTime = new Date(this.state.leave);
+      this.updateEnterAndLeaveDate(
+        DateUtil.setHoursToMin(this.state.enter),
+        DateUtil.setHoursToMax(this.state.leave),
+      );
+    } else {
+      this.updateEnterAndLeaveDate(
+        this.resetEnterTime ?? null,
+        this.resetLeaveTime ?? null,
+      );
+    }
+
+    this.setState(
+      {
+        selectionAllDay: enabled,
+      },
+      () => onDone?.(),
+    );
+  };
+
+  toggleAllDaySelection = () => {
+    this.setAllDaySelection(!this.state.selectionAllDay);
+  };
+
+  applyQuickDatePreset = (
+    preset: "today" | "tomorrow" | "next2h" | "fullday",
+  ) => {
+    if (!this.state.locationId) {
+      return;
+    }
+
+    if (preset === "fullday") {
+      this.setAllDaySelection(true);
+      return;
+    }
+
+    if (preset === "next2h") {
+      const start = new Date();
+      start.setMinutes(0, 0, 0);
+      start.setHours(start.getHours() + 1);
+      const end = new Date(start);
+      end.setHours(start.getHours() + 2);
+
+      this.setState({ selectionMultiDay: false }, () => {
+        this.setAllDaySelection(false, () => {
+          this.updateEnterAndLeaveDate(start, end);
+        });
+      });
+      return;
+    }
+
+    const targetDay =
+      preset === "today" ? DateUtil.getTodayStart() : DateUtil.nextDay(new Date());
+    const nextEnter = DateUtil.copyDate(targetDay, new Date(this.state.enter));
+    const nextLeave = DateUtil.copyDate(targetDay, new Date(this.state.leave));
+
+    if (!this.state.selectionMultiDay && nextLeave.getTime() <= nextEnter.getTime()) {
+      nextLeave.setTime(nextEnter.getTime() + 60 * 60 * 1000);
+    }
+
+    this.updateEnterAndLeaveDate(nextEnter, nextLeave);
+  };
+
