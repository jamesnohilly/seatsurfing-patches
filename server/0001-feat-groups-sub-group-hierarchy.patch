+func TestGroupIsAncestor(t *testing.T) {
+	ClearTestDB()
+	org := CreateTestOrg("test.com")
+
+	grandparent := &Group{OrganizationID: org.ID, Name: "Grandparent"}
+	GetGroupRepository().Create(grandparent)
+
+	parent := &Group{OrganizationID: org.ID, Name: "Parent", ParentID: grandparent.ID}
+	GetGroupRepository().Create(parent)
+
+	child := &Group{OrganizationID: org.ID, Name: "Child", ParentID: parent.ID}
+	GetGroupRepository().Create(child)
+
+	unrelated := &Group{OrganizationID: org.ID, Name: "Unrelated"}
+	GetGroupRepository().Create(unrelated)
+
+	// Self is ancestor of self
+	isAncestor, err := GetGroupRepository().IsAncestor(grandparent.ID, grandparent.ID)
+	CheckTestBool(t, true, err == nil)
+	CheckTestBool(t, true, isAncestor)
+
+	// Grandparent is ancestor of parent
+	isAncestor, err = GetGroupRepository().IsAncestor(parent.ID, grandparent.ID)
+	CheckTestBool(t, true, err == nil)
+	CheckTestBool(t, true, isAncestor)
+
+	// Grandparent is ancestor of child (transitive)
+	isAncestor, err = GetGroupRepository().IsAncestor(child.ID, grandparent.ID)
+	CheckTestBool(t, true, err == nil)
+	CheckTestBool(t, true, isAncestor)
+
+	// Child is NOT ancestor of grandparent
+	isAncestor, err = GetGroupRepository().IsAncestor(grandparent.ID, child.ID)
+	CheckTestBool(t, true, err == nil)
+	CheckTestBool(t, false, isAncestor)
+
+	// Unrelated group is not an ancestor of anything
+	isAncestor, err = GetGroupRepository().IsAncestor(child.ID, unrelated.ID)
+	CheckTestBool(t, true, err == nil)
+	CheckTestBool(t, false, isAncestor)
+}
