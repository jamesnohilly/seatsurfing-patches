+func TestGroupSubGroupParentID(t *testing.T) {
+	ClearTestDB()
+	org := CreateTestOrg("test.com")
+
+	parent := &Group{OrganizationID: org.ID, Name: "Parent"}
+	GetGroupRepository().Create(parent)
+
+	child := &Group{OrganizationID: org.ID, Name: "Child", ParentID: parent.ID}
+	err := GetGroupRepository().Create(child)
+	CheckTestBool(t, true, err == nil)
+
+	res, err := GetGroupRepository().GetOne(child.ID)
+	CheckTestBool(t, true, err == nil)
