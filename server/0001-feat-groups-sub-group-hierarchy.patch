+// IsAncestor returns true if ancestorID is an ancestor of groupID (or equals groupID),
+// which would create a cycle if ancestorID were set as parent of groupID.
+func (r *GroupRepository) IsAncestor(groupID, ancestorID string) (bool, error) {
+	var count int
+	err := GetDatabase().DB().QueryRow(
+		"WITH RECURSIVE ancestors AS ("+
+			"SELECT id, parent_id FROM groups WHERE id = $1 "+
+			"UNION ALL "+
+			"SELECT g.id, g.parent_id FROM groups g JOIN ancestors a ON g.id = a.parent_id"+
+			") SELECT COUNT(*) FROM ancestors WHERE id = $2",
+		groupID, ancestorID).Scan(&count)
+	if err != nil {
+		return false, err
+	}
+	return count > 0, nil
+}
